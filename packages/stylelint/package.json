{
  "name": "@nijesmik/stylelint-config",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bem": {
      "types": "./dist/bem.d.ts",
      "import": "./dist/bem.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup index.ts bem.ts --format esm --dts"
  },
  "dependencies": {
    "@stylistic/stylelint-plugin": "^5.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.0"
  },
  "peerDependencies": {
    "stylelint": ">=17.0.0"
  },
  "devDependencies": {
    "stylelint": "^17.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}